# 基础配置
APP_NAME=AI-API-Proxy
SECRET_KEY=your-random-secret-key-at-least-32-chars-change-this
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# 数据库（开发用 SQLite，生产用 MySQL）
DATABASE_URL=sqlite:///./proxy.db
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/apiproxy

# Redis（可选，不配置则使用内存限流）
# REDIS_URL=redis://localhost:6379/0

# 服务监听
HOST=0.0.0.0
PORT=8000

# 计费倍率（默认1.0，即按成本价转发）
DEFAULT_MULTIPLIER=1.0

# 安全
CORS_ORIGINS=*
MAX_REQUEST_SIZE=10485760

# 熔断阈值（连续错误次数超过此值自动禁用渠道）
CIRCUIT_BREAKER_THRESHOLD=5

# ──────────────────────────────────────────────
# USDT 收款配置（必填，否则充值功能不可用）
# ──────────────────────────────────────────────
USDT_TRC20_ADDRESS=你的TRC20收款地址
USDT_ERC20_ADDRESS=你的ERC20收款地址
# 汇率：1 USDT = X USD 额度（可调高赚差价，如1.0表示1:1）
USDT_TO_USD_RATE=1.0

# 站点信息
SITE_NAME=NexusAI Gateway
SITE_URL=http://localhost:8000
